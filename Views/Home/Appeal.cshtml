@model Appeal

@{
    ViewData["Title"] = "Обращение";
}

<h1>@ViewData["Title"]</h1>

<p class="lead">
    На этой странице можно разместить форму обратной связи для родителей и законных представителей.
    В учебной версии обращение сохраняется в базе данных SQLite.
</p>

@if (TempData["AppealMessage"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["AppealMessage"]
    </div>
}

<form asp-action="Appeal" method="post" class="appeal-form">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="form-group">
        <label asp-for="FullName">ФИО</label>
        <input asp-for="FullName" class="form-control" placeholder="Введите ФИО" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Email">Электронная почта</label>
        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Phone">Телефон</label>
        <input asp-for="Phone" class="form-control" placeholder="+7 (000) 000-00-00" />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Message">Текст обращения</label>
        <textarea asp-for="Message" class="form-control" rows="5" placeholder="Введите текст обращения"></textarea>
        <span asp-validation-for="Message" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Отправить</button>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
