@model Employee

@{
    ViewData["Title"] = "Детали сотрудника";
}

<h1>@ViewData["Title"]</h1>

<dl class="row bg-white p-3 border rounded">
    <dt class="col-sm-3">ФИО</dt>
    <dd class="col-sm-9">@Model.FullName</dd>
    <dt class="col-sm-3">Должность</dt>
    <dd class="col-sm-9">@Model.Position</dd>
    <dt class="col-sm-3">Отдел</dt>
    <dd class="col-sm-9">@Model.Department</dd>
    <dt class="col-sm-3">Телефон</dt>
    <dd class="col-sm-9">@Model.Phone</dd>
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
</dl>

<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a>
<a class="btn btn-secondary" asp-action="Index">Назад</a>
