@model IEnumerable<SchoolClass>

@{
    ViewData["Title"] = "Управление классами";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    <a class="btn btn-primary" asp-action="Create">Добавить класс</a>
</div>

<table class="table table-striped table-bordered bg-white">
    <thead>
        <tr>
            <th>Название</th>
            <th>Описание</th>
            <th>Ученики</th>
            <th class="text-nowrap">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Students.Count</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a href="/Admin">Назад в админку</a>
