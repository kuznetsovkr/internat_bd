@model SchoolClass

@{
    ViewData["Title"] = "Удалить класс";
}

<h1>@ViewData["Title"]</h1>

<div class="alert alert-warning">
    Вы действительно хотите удалить класс «@Model.Name»?
    @if (Model.Students.Any())
    {
        <span>Вместе с классом будут удалены ученики этого класса: @Model.Students.Count.</span>
    }
</div>

<form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a class="btn btn-secondary" asp-action="Index">Отмена</a>
</form>
