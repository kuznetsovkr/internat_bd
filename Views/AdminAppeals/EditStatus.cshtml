@model Appeal

@{
    ViewData["Title"] = "Изменить статус обращения";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="EditStatus" asp-route-id="@Model.Id" method="post" class="appeal-form">
    <div class="form-group">
        <label>Заявитель</label>
        <input class="form-control" value="@Model.FullName" disabled />
    </div>
    <div class="form-group">
        <label asp-for="Status">Статус</label>
        <select asp-for="Status" class="form-control">
            <option value="Новое">Новое</option>
            <option value="В работе">В работе</option>
            <option value="Закрыто">Закрыто</option>
        </select>
        <span class="text-danger">@Html.ValidationMessage("Status")</span>
    </div>
    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a class="btn btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Отмена</a>
</form>
