@model Appeal

@{
    ViewData["Title"] = "Удалить обращение";
}

<h1>@ViewData["Title"]</h1>

<div class="alert alert-warning">Вы действительно хотите удалить обращение от «@Model.FullName»?</div>

<form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a class="btn btn-secondary" asp-action="Index">Отмена</a>
</form>
