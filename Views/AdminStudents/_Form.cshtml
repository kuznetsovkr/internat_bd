@model Student

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="form-group">
    <label asp-for="FullName">ФИО</label>
    <input asp-for="FullName" class="form-control" />
    <span asp-validation-for="FullName" class="text-danger"></span>
</div>
<div class="form-group">
    <label asp-for="BirthDate">Дата рождения</label>
    <input asp-for="BirthDate" class="form-control" type="date" />
    <span asp-validation-for="BirthDate" class="text-danger"></span>
</div>
<div class="form-group">
    <label asp-for="SchoolClassId">Класс</label>
    <select asp-for="SchoolClassId" class="form-control" asp-items="ViewBag.SchoolClassId"></select>
    <span asp-validation-for="SchoolClassId" class="text-danger"></span>
</div>
