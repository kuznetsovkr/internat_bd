@model Student

@{
    ViewData["Title"] = "Удалить ученика";
}

<h1>@ViewData["Title"]</h1>

<div class="alert alert-warning">
    Вы действительно хотите удалить ученика «@Model.FullName» из класса @Model.SchoolClass?.Name?
</div>

<form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a class="btn btn-secondary" asp-action="Index">Отмена</a>
</form>
