@model IEnumerable<Student>

@{
    ViewData["Title"] = "Управление учениками";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    <a class="btn btn-primary" asp-action="Create">Добавить ученика</a>
</div>

<table class="table table-striped table-bordered bg-white">
    <thead>
        <tr>
            <th>ФИО</th>
            <th>Дата рождения</th>
            <th>Класс</th>
            <th class="text-nowrap">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td class="text-nowrap">@item.BirthDate.ToString("dd.MM.yyyy")</td>
                <td>@item.SchoolClass?.Name</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a href="/Admin">Назад в админку</a>
