@{
    ViewData["Title"] = "Админка";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4 mb-3">
        <a class="card h-100 text-decoration-none text-dark" href="/Admin/News">
            <div class="card-body">
                <h2 class="h5">Новости</h2>
                <p class="mb-0">Создание и редактирование новостей школы.</p>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a class="card h-100 text-decoration-none text-dark" href="/Admin/Employees">
            <div class="card-body">
                <h2 class="h5">Сотрудники</h2>
                <p class="mb-0">Управление списком работников.</p>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a class="card h-100 text-decoration-none text-dark" href="/Admin/Events">
            <div class="card-body">
                <h2 class="h5">Мероприятия</h2>
                <p class="mb-0">Планирование школьных событий.</p>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a class="card h-100 text-decoration-none text-dark" href="/Admin/Appeals">
            <div class="card-body">
                <h2 class="h5">Обращения</h2>
                <p class="mb-0">Просмотр обращений и изменение статусов.</p>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a class="card h-100 text-decoration-none text-dark" href="/Admin/Classes">
            <div class="card-body">
                <h2 class="h5">Классы</h2>
                <p class="mb-0">Создание и редактирование классов.</p>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a class="card h-100 text-decoration-none text-dark" href="/Admin/Students">
            <div class="card-body">
                <h2 class="h5">Ученики</h2>
                <p class="mb-0">Ведение списка учеников по классам.</p>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a class="card h-100 text-decoration-none text-dark" href="/Admin/Documents">
            <div class="card-body">
                <h2 class="h5">Документы</h2>
                <p class="mb-0">Управление документами сайта.</p>
            </div>
        </a>
    </div>
</div>
