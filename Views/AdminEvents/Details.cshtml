@model EventItem

@{
    ViewData["Title"] = "Детали мероприятия";
}

<h1>@ViewData["Title"]</h1>

<dl class="row bg-white p-3 border rounded">
    <dt class="col-sm-3">Название</dt>
    <dd class="col-sm-9">@Model.Title</dd>
    <dt class="col-sm-3">Дата</dt>
    <dd class="col-sm-9">@Model.EventDate.ToString("dd.MM.yyyy")</dd>
    <dt class="col-sm-3">Место</dt>
    <dd class="col-sm-9">@Model.Place</dd>
    <dt class="col-sm-3">Описание</dt>
    <dd class="col-sm-9">@Model.Description</dd>
</dl>

<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a>
<a class="btn btn-secondary" asp-action="Index">Назад</a>
