@model NewsItem

@{
    ViewData["Title"] = "Детали новости";
}

<h1>@ViewData["Title"]</h1>

<div class="card">
    <div class="card-body">
        <p class="text-muted">@Model.PublishDate.ToString("dd.MM.yyyy")</p>
        <h2 class="h4">@Model.Title</h2>
        <p class="font-weight-bold">@Model.ShortDescription</p>
        <p>@Model.Content</p>
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <p class="mb-0">Изображение: @Model.ImageUrl</p>
        }
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a>
    <a class="btn btn-secondary" asp-action="Index">Назад</a>
</div>
